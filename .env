# Askandarani Phone — Environment Variables
# ============================================
# This file is used for LOCAL development.
# For VERCEL: add DATABASE_URL in Vercel Dashboard → Settings → Environment Variables

# VERCEL / Production — Use PostgreSQL:
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# For local development, use a local PostgreSQL database URL here instead.
# Example: DATABASE_URL="postgresql://postgres:password@localhost:5432/askandarani"
# Seeded admin login (when running npm run seed):
# ADMIN_EMAIL=admin@askandarani.phone
# ADMIN_PASSWORD=admin123
